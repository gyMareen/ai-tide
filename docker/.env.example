# AI-Tide Docker Environment Variables

# ============================================
# MySQL Configuration
# ============================================
MYSQL_ROOT_PASSWORD=change_this_in_production
MYSQL_DATABASE=ai_tide
MYSQL_USER=ai_tide_user
MYSQL_PASSWORD=change_this_in_production

# ============================================
# Redis Configuration
# ============================================
# No additional environment variables needed for Redis

# ============================================
# Spring Boot Application Configuration
# ============================================
SPRING_PROFILES_ACTIVE=prod

# JWT Secret Key (change this in production and keep secure)
JWT_SECRET=ai_tide_jwt_secret_change_this_in_production
JWT_EXPIRATION=7200000

# ============================================
# Frontend Configuration
# ============================================
VITE_API_BASE_URL=http://localhost:8080/api

# ============================================
# Nginx Configuration
# ============================================
NGINX_SERVER_NAME=ai-tide.com
